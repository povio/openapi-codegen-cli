{
  "name": "@povio/openapi-codegen-cli",
  "version": "2.0.0",
  "main": "./dist/index.cjs",
  "bin": {
    "openapi-codegen": "./dist/sh.cjs"
  },
  "scripts": {
    "start": "node --import tsx ./src/sh.ts",
    "start:dist": "node ./dist/sh.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf ./dist ./tmp",
    "build": "yarn clean && tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome format --write --fix",
    "check": "yarn typecheck && yarn lint && yarn test",
    "push": "yarn exec ./scripts/publish.sh",
    "dev:generate": "rimraf ./tmp/output && yarn start generate --cwd test --config ./config.ts",
    "dev:check": "yarn start check --config ./test/config.ts"
  },
  "files": [
    "dist/*",
    "resources/assets/**",
    "README.md"
  ],
  "keywords": [
    "povio",
    "openapi",
    "codegen",
    "zod",
    "react-query"
  ],
  "homepage": "https://github.com/povio/openapi-codegen-cli",
  "bugs": "https://github.com/povio/openapi-codegen-cli/issues",
  "repository": {
    "url": "git+https://github.com/povio/openapi-codegen-cli.git",
    "type": "git"
  },
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@biomejs/biome": "^2.3.10",
    "@types/node": "^25.0.3",
    "chalk": "^5.6.2",
    "handlebars": "^4.7.8",
    "import-fresh": "^3.3.1",
    "openapi-types": "^12.1.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.2",
    "ts-pattern": "^5.9.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "type-fest": "^5.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "yargs": "^18.0.0",
    "zod": "^4.2.1"
  },
  "engines": {
    "node": ">= 20",
    "yarn": ">= 3.2",
    "npm": ">= 8"
  },
  "packageManager": "yarn@4.12.0"
}
